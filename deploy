#!/usr/bin/env bash
set -e
if [[ ! -d .git ]]; then
  echo "please run deploy under the git repo root."
  exit 1
fi

if [[ ! -d pkg ]]; then
  echo "pkg/ not found. run 'npm run build' first."
  exit 1
fi

REV=$(git describe --always)
rm -rf _release
git clone $(git remote get-url origin) --depth 1 -b release _release 2>/dev/null || {
  git clone $(git remote get-url origin) --depth 1 _release
  cd _release
  git checkout --orphan release
  git rm -rf . 2>/dev/null || true
  cd ..
}

cd _release
git rm -rf . 2>/dev/null || true

cp -R ../pkg/. ./
[[ -f ../README.md  ]] && cp ../README.md  ./
[[ -f ../CHANGELOG.md ]] && cp ../CHANGELOG.md ./

git add -A
git commit -m "release for $REV"
git push origin release
cd ..
rm -rf _release
